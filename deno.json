{
  "nodeModulesDir": "auto",
  "unstable": ["sloppy-imports"],
  "workspace": [
    "./packages/solid-stately",
    "./packages/solidaria",
    "./packages/solidaria-components",
    "./packages/solidaria-test-utils",
    "./packages/silapse-test-utils",
    "./packages/silapse",
    "./apps/web"
  ],
  "tasks": {
    "install": "deno install",
    "build": "deno task typecheck && deno task build:stately && deno task build:solidaria && deno task build:components && deno task build:silapse",
    "build:stately": "deno run -A scripts/build.ts solid-stately",
    "build:solidaria": "deno run -A scripts/build.ts solidaria",
    "build:components": "deno run -A scripts/build.ts solidaria-components",
    "build:silapse": "deno run -A scripts/build.ts silapse",
    "test": "bun run vitest run",
    "test:watch": "bun run vitest",
    "test:e2e": "cd apps/web && bun run playwright test",
    "dev": "cd apps/web && deno task dev",
    "comparison:install": "cd apps/comparison && npm install --workspaces=false",
    "comparison:dev": "cd apps/comparison && npm exec --workspaces=false -- astro dev",
    "comparison:dev:worker": "deno task comparison:build && XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler node_modules/.bin/wrangler dev --config apps/comparison/wrangler.jsonc",
    "comparison:build": "cd apps/comparison && npm exec --workspaces=false -- astro build",
    "comparison:preview": "cd apps/comparison && npm exec --workspaces=false -- astro preview",
    "comparison:typecheck": "cd apps/comparison && npm exec --workspaces=false -- astro check",
    "comparison:types": "XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler node_modules/.bin/wrangler types apps/comparison/src/worker-configuration.d.ts --config apps/comparison/wrangler.jsonc",
    "comparison:deploy": "deno task comparison:build && XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler node_modules/.bin/wrangler deploy --config apps/comparison/wrangler.jsonc",
    "comparison:deploy:dry-run": "deno task comparison:build && XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler node_modules/.bin/wrangler deploy --dry-run --config apps/comparison/wrangler.jsonc",
    "typecheck": "deno check packages/*/src/**/*.ts packages/*/src/**/*.tsx packages/*/test-utils/**/*.ts",
    "typecheck:web": "deno run -A npm:typescript/tsc -p apps/web/tsconfig.json --noEmit",
    "typecheck:all": "deno task typecheck",
    "guard:docs-routes": "deno run -A scripts/check-doc-routes.ts",
    "guard:rac-parity": "deno run -A scripts/check-rac-parity.ts",
    "guard:rac-export-gap": "deno run -A scripts/check-rac-export-gap.ts",
    "guard:rac-export-diff": "deno run -A scripts/diff-react-spectrum-exports.ts",
    "guard:layer-parity": "deno run -A scripts/check-layer-parity.ts",
    "guard:dnd-keyboard-parity": "deno run -A scripts/check-dnd-keyboard-parity.ts",
    "guard:virtualizer-keyboard-parity": "deno run -A scripts/check-virtualizer-keyboard-parity.ts",
    "watch:rac:new-entry": "deno run -A scripts/new-rac-watch-entry.ts",
    "changeset": "npm run changeset",
    "changeset:status": "npm run changeset:status",
    "changeset:version": "npm run changeset:version",
    "changeset:publish": "npm run changeset:publish",
    "sync:manifest-versions": "npm run sync:manifest-versions",
    "check:manifest-versions": "npm run check:manifest-versions",
    "version:set": "deno run -A scripts/version.ts",
    "publish": "deno run -A scripts/publish.ts",
    "release:legacy": "deno task build && deno task publish",
    "release": "npm run release:local",
    "bench:bundle": "deno run -A benchmarks/bundle-size/analyze.ts",
    "bench:runtime": "bun run vitest run benchmarks/runtime",
    "bench:vitals": "cd benchmarks/web-vitals && bun run playwright test",
    "bench:all": "deno task bench:bundle && deno task bench:runtime && deno task bench:vitals"
  },
  "imports": {
    "solid-js": "npm:solid-js@^1.9.0",
    "solid-js/web": "npm:solid-js@^1.9.0/web",
    "solid-js/store": "npm:solid-js@^1.9.0/store",
    "@internationalized/date": "npm:@internationalized/date@^3.8.0",
    "@internationalized/string": "npm:@internationalized/string@^3.2.5",
    "esbuild": "npm:esbuild@^0.24.0",
    "esbuild-plugin-solid": "npm:esbuild-plugin-solid@^0.6.0",
    "@testing-library/user-event": "npm:@testing-library/user-event@^14.0.0",
    "@solidjs/testing-library": "npm:@solidjs/testing-library@^0.8.0",
    "@proyecto-viviana/solid-stately": "./packages/solid-stately/src/index.ts",
    "@proyecto-viviana/solidaria": "./packages/solidaria/src/index.ts",
    "@proyecto-viviana/solidaria-components": "./packages/solidaria-components/src/index.ts",
    "@proyecto-viviana/silapse": "./packages/silapse/src/index.ts",
    "@proyecto-viviana/solidaria-test-utils": "./packages/solidaria-test-utils/src/index.ts",
    "@proyecto-viviana/silapse-test-utils": "./packages/silapse-test-utils/src/index.ts"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "strict": true,
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "react-spectrum"
  ]
}
