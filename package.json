{
  "name": "proyecto-viviana-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for VivianaCorp SolidJS libraries",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "dev": "bun run --filter './examples/*' dev",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^25.0.1",
    "solid-js": "^1.9.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite-plugin-solid": "^2.10.2",
    "vitest": "^2.1.8"
  }
}
