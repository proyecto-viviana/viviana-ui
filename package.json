{
  "name": "proyecto-viviana-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Proyecto Viviana SolidJS libraries",
  "type": "module",
  "scripts": {
    "build": "pnpm run typecheck && pnpm run build:stately && pnpm run build:solidaria && pnpm run build:components && pnpm run build:silapse",
    "build:stately": "pnpm run --filter @proyecto-viviana/solid-stately build",
    "build:solidaria": "pnpm run --filter @proyecto-viviana/solidaria build",
    "build:components": "pnpm run --filter @proyecto-viviana/solidaria-components build",
    "build:silapse": "pnpm run --filter @proyecto-viviana/silapse build",
    "build:web": "pnpm run --filter @proyecto-viviana/web build",
    "dev": "pnpm run --filter @proyecto-viviana/web dev",
    "start": "pnpm run --filter @proyecto-viviana/web start",
    "deploy": "pnpm run --filter @proyecto-viviana/web deploy",
    "comparison:install": "cd apps/comparison && pnpm install",
    "comparison:dev": "pnpm run --filter @proyecto-viviana/comparison dev",
    "comparison:build": "pnpm run --filter @proyecto-viviana/comparison build",
    "comparison:preview": "pnpm run --filter @proyecto-viviana/comparison preview",
    "comparison:typecheck": "pnpm run --filter @proyecto-viviana/comparison typecheck",
    "comparison:types": "pnpm run --filter @proyecto-viviana/comparison types",
    "comparison:dev:worker": "pnpm run --filter @proyecto-viviana/comparison dev:worker",
    "comparison:deploy": "pnpm run --filter @proyecto-viviana/comparison deploy",
    "comparison:deploy:dry-run": "pnpm run --filter @proyecto-viviana/comparison deploy:dry-run",
    "test": "vp test packages",
    "test:run": "vp test run packages",
    "test:watch": "vp test packages",
    "test:e2e": "pnpm --filter @proyecto-viviana/web exec playwright test",
    "a11y:axe:aa": "RUN_AXE=1 pnpm --filter @proyecto-viviana/web exec playwright test e2e/playground-axe.spec.ts -g \"WCAG 2.2 AA\" --reporter=line",
    "a11y:axe:playground": "RUN_AXE=1 AXE_INCLUDE_CONTRAST=1 pnpm --filter @proyecto-viviana/web exec playwright test e2e/playground-axe.spec.ts --reporter=line",
    "a11y:smoke": "pnpm --filter @proyecto-viviana/web exec playwright test e2e/docs-menu.spec.ts e2e/playground-components.spec.ts e2e/calendar-regression.spec.ts --reporter=line",
    "a11y:check": "pnpm run a11y:axe:aa && pnpm run a11y:smoke",
    "a11y:full": "pnpm run a11y:axe:playground && pnpm run a11y:smoke",
    "a11y:ci": "pnpm run a11y:check",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck:web": "pnpm run build && tsc -p apps/web/tsconfig.json --noEmit",
    "typecheck:all": "pnpm run typecheck && pnpm run typecheck:web",
    "guard:docs-routes": "npx tsx scripts/check-doc-routes.ts",
    "guard:rac-parity": "npx tsx scripts/check-rac-parity.ts",
    "guard:rac-export-gap": "npx tsx scripts/check-rac-export-gap.ts",
    "guard:rac-export-diff": "npx tsx scripts/diff-react-spectrum-exports.ts",
    "guard:layer-parity": "npx tsx scripts/check-layer-parity.ts",
    "guard:dnd-keyboard-parity": "npx tsx scripts/check-dnd-keyboard-parity.ts",
    "guard:virtualizer-keyboard-parity": "npx tsx scripts/check-virtualizer-keyboard-parity.ts",
    "watch:rac:new-entry": "npx tsx scripts/new-rac-watch-entry.ts",
    "bench:bundle": "npx tsx benchmarks/bundle-size/analyze.ts",
    "bench:runtime": "vp test run benchmarks/runtime",
    "bench:vitals": "pnpm --filter benchmarks-web-vitals exec playwright test",
    "bench:all": "pnpm run bench:bundle && pnpm run bench:runtime && pnpm run bench:vitals",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "ci:changesets": "npx tsx scripts/check-changeset-required.mjs && pnpm run changeset:status",
    "ci:release-readiness": "pnpm run build && pnpm run test:run",
    "ci:a11y": "pnpm run a11y:check",
    "pr:check:fast": "pnpm run ci:changesets && pnpm run ci:release-readiness",
    "pr:check": "pnpm run pr:check:fast && pnpm run ci:a11y",
    "release:prepare": "pnpm run changeset:version && pnpm run ci:release-readiness",
    "release:npm": "pnpm run changeset:publish",
    "release:publish": "pnpm run release:npm",
    "release": "pnpm run release:prepare && pnpm run release:publish",
    "release:local": "pnpm run release"
  },
  "dependencies": {
    "brotli-size": "^4.0.0",
    "gzip-size": "^7.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.0",
    "axe-core": "^4.10.0",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.5.2",
    "esbuild-plugin-solid": "^0.6.0",
    "jsdom": "^27.3.0",
    "rimraf": "^6.1.2",
    "solid-js": "^1.9.11",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-solid": "^2.11.10",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wrangler": "^4.67.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "packageManager": "pnpm@10.33.0"
}