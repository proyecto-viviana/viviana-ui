{
  "name": "proyecto-viviana-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Proyecto Viviana SolidJS libraries",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/solid-stately build && bun run --cwd packages/solidaria build && bun run --cwd packages/solidaria-components build && bun run --cwd packages/ui build",
    "build:web": "bun run --cwd apps/web build",
    "dev": "bun run --cwd apps/web dev",
    "start": "bun run --cwd apps/web start",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.4",
    "jsdom": "^25.0.1",
    "solid-js": "^1.9.10",
    "typescript": "^5.7.2",
    "vite-plugin-solid": "^2.10.2",
    "vitest": "^2.1.8"
  }
}
