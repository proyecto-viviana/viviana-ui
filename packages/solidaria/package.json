{
  "name": "@proyecto-viviana/solidaria",
  "version": "0.2.6",
  "description": "A 1-1 SolidJS port of React Aria - accessible UI primitives",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && rm -f tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "prepublishOnly": "echo 'Use the root Changesets/JSR release workflow'"
  },
  "dependencies": {
    "@proyecto-viviana/solid-stately": "^0.2.5",
    "@internationalized/string": "^3.2.5"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.11"
  },
  "keywords": [
    "solid",
    "solidjs",
    "aria",
    "accessibility",
    "a11y",
    "react-aria"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/proyecto-viviana/proyecto-viviana"
  },
  "publishConfig": {
    "access": "public"
  }
}
