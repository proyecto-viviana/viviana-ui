{
  "name": "@proyecto-viviana/solidaria",
  "version": "0.0.1",
  "description": "A 1-1 SolidJS port of React Aria - accessible UI primitives",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "solid": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.10"
  },
  "keywords": [
    "solid",
    "solidjs",
    "aria",
    "accessibility",
    "a11y",
    "react-aria"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivianacorp/proyecto-viviana"
  }
}
