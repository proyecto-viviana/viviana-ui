{
  "name": "@proyecto-viviana/solidaria",
  "version": "0.2.5",
  "license": "Apache-2.0",
  "exports": "./src/index.ts",
  "tasks": {
    "build": "deno run -A ../../scripts/build.ts solidaria",
    "build:types": "deno run -A npm:typescript/tsc -p tsconfig.build.json"
  },
  "imports": {
    "solid-js": "npm:solid-js@^1.9.0",
    "solid-js/web": "npm:solid-js@^1.9.0/web",
    "solid-js/store": "npm:solid-js@^1.9.0/store",
    "@internationalized/string": "npm:@internationalized/string@^3.2.5",
    "@proyecto-viviana/solid-stately": "jsr:@proyecto-viviana/solid-stately@^0.2.4",
    "axe-core": "npm:axe-core@^4.10.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "strict": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "deno.ns"
    ]
  }
}
