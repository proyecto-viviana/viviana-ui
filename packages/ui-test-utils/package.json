{
  "name": "@proyecto-viviana/ui-test-utils",
  "version": "0.0.8",
  "description": "Testing utilities for ui components",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/user-event": "^14.6.1"
  }
}
