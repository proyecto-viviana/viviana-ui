{
  "name": "@proyecto-viviana/solid-spectrum",
  "version": "0.4.2",
  "description": "Spectrum 2-compatible styled components for SolidJS",
  "keywords": [
    "components",
    "design-system",
    "solid",
    "solid-spectrum",
    "solidjs",
    "spectrum-2"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proyecto-viviana/proyecto-viviana.git",
    "directory": "packages/solid-spectrum"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme.css": {
      "import": "./dist/theme.css",
      "default": "./src/theme.css"
    },
    "./styles.css": {
      "import": "./dist/styles.css",
      "default": "./src/styles.css"
    },
    "./components.css": {
      "import": "./dist/components.css",
      "default": "./src/components.css"
    },
    "./style": {
      "types": "./dist/s2-style/index.d.ts",
      "solid": "./src/s2-style/index.ts",
      "import": "./dist/s2-style/index.js",
      "default": "./dist/s2-style/index.js"
    },
    "./style/runtime": {
      "types": "./dist/s2-style/runtime.d.ts",
      "solid": "./src/s2-style/runtime.ts",
      "import": "./dist/s2-style/runtime.js",
      "default": "./dist/s2-style/runtime.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsx ../../scripts/generate-solid-spectrum-s2-css.ts && tsup && rm -f tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "prepublishOnly": "echo 'Use the root Changesets npm release workflow'"
  },
  "dependencies": {
    "@adobe/spectrum-tokens": "^14.5.0",
    "@proyecto-viviana/solid-stately": "workspace:*",
    "@proyecto-viviana/solidaria": "workspace:*",
    "@proyecto-viviana/solidaria-components": "workspace:*",
    "csstype": "^3.2.3"
  },
  "devDependencies": {
    "@proyecto-viviana/solid-spectrum-test-utils": "workspace:*",
    "solid-js": "^1.9.11"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  }
}
