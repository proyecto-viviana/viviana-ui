{
  "name": "@vivianacorp/solid-aria",
  "version": "0.0.1",
  "description": "A 1-1 SolidJS port of React Aria - accessible UI primitives",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.3"
  },
  "keywords": [
    "solid",
    "solidjs",
    "aria",
    "accessibility",
    "a11y",
    "react-aria"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/viviana-corp/solid-aria"
  }
}
