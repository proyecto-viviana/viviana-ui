{
  "name": "@proyecto-viviana/silapse",
  "version": "0.4.1",
  "description": "Styled UI components for SolidJS - inspired by React Spectrum",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme.css": {
      "import": "./dist/theme.css",
      "default": "./src/theme.css"
    },
    "./styles.css": {
      "import": "./dist/styles.css",
      "default": "./src/styles.css"
    },
    "./components.css": {
      "import": "./dist/components.css",
      "default": "./src/components.css"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup && rm -f tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "prepublishOnly": "echo 'Use the root Changesets npm release workflow'"
  },
  "dependencies": {
    "@proyecto-viviana/solid-stately": "^0.2.6",
    "@proyecto-viviana/solidaria": "^0.2.7",
    "@proyecto-viviana/solidaria-components": "^0.2.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.11"
  },
  "keywords": [
    "solid",
    "solidjs",
    "silapse",
    "components",
    "design-system"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/proyecto-viviana/proyecto-viviana"
  },
  "publishConfig": {
    "access": "public"
  }
}
