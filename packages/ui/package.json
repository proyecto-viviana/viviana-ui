{
  "name": "@proyecto-viviana/ui",
  "version": "0.1.7",
  "description": "Styled UI components for SolidJS - inspired by React Spectrum",
  "type": "module",
  "main": "./dist/index.ssr.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme.css": {
      "import": "./dist/theme.css",
      "default": "./src/theme.css"
    },
    "./styles.css": {
      "import": "./dist/styles.css",
      "default": "./src/styles.css"
    },
    "./components.css": {
      "import": "./dist/components.css",
      "default": "./src/components.css"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@proyecto-viviana/solidaria": "workspace:*",
    "@proyecto-viviana/solidaria-components": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.10"
  },
  "keywords": [
    "solid",
    "solidjs",
    "ui",
    "components",
    "design-system"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/proyecto-viviana/proyecto-viviana"
  },
  "publishConfig": {
    "access": "public"
  }
}
