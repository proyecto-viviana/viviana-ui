{
  "name": "@proyecto-viviana/ui",
  "version": "0.1.2",
  "description": "Styled UI components for SolidJS - inspired by React Spectrum",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "solid": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme.css": "./dist/theme.css",
    "./styles.css": "./dist/styles.css",
    "./components.css": "./dist/components.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "rimraf dist tsconfig.build.tsbuildinfo && vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@proyecto-viviana/solidaria": "^0.0.2",
    "@proyecto-viviana/solidaria-components": "^0.0.2"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.10"
  },
  "keywords": [
    "solid",
    "solidjs",
    "ui",
    "components",
    "design-system"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/proyecto-viviana/proyecto-viviana"
  },
  "publishConfig": {
    "access": "public"
  }
}
