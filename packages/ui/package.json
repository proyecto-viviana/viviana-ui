{
  "name": "@proyecto-viviana/ui",
  "version": "0.0.1",
  "description": "Styled UI components for SolidJS - inspired by React Spectrum",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "solid": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./theme.css": "./src/theme.css",
    "./styles.css": "./src/styles.css",
    "./components.css": "./src/components.css",
    "./assets/*": "./src/assets/*"
  },
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@proyecto-viviana/solidaria": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.10"
  },
  "keywords": [
    "solid",
    "solidjs",
    "ui",
    "components",
    "design-system"
  ],
  "license": "MIT"
}
