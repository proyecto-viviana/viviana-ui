{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "types": ["bun-types"],
    "paths": {
      "@solidaria/*": ["./packages/*/src"],
      "@proyecto-viviana/solid-stately": ["./packages/solid-stately/src/index.ts"],
      "@proyecto-viviana/solidaria": ["./packages/solidaria/src/index.ts"],
      "@proyecto-viviana/solidaria-components": ["./packages/solidaria-components/src/index.ts"],
      "@proyecto-viviana/ui": ["./packages/ui/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*", "packages/*/build.ts"],
  "exclude": ["node_modules", "dist"]
}
