{
  "name": "@proyecto-viviana/comparison",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Astro comparison app for React Spectrum and Proyecto Viviana parity review",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "dev:worker": "XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler ../../node_modules/.bin/wrangler dev --config wrangler.jsonc",
    "types": "XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler ../../node_modules/.bin/wrangler types src/worker-configuration.d.ts --config wrangler.jsonc",
    "deploy": "bun run build && XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler ../../node_modules/.bin/wrangler deploy --config wrangler.jsonc",
    "deploy:dry-run": "bun run build && XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler ../../node_modules/.bin/wrangler deploy --dry-run --config wrangler.jsonc"
  },
  "overrides": {
    "lodash": "^4.17.23"
  },
  "dependencies": {
    "@proyecto-viviana/silapse": "^0.4.0",
    "@proyecto-viviana/solid-stately": "^0.2.5",
    "@proyecto-viviana/solidaria": "^0.2.6",
    "@proyecto-viviana/solidaria-components": "^0.2.7",
    "@astrojs/react": "^4.2.2",
    "@astrojs/solid-js": "^5.1.1",
    "@react-spectrum/button": "3.17.6",
    "@react-spectrum/provider": "3.10.13",
    "@react-spectrum/tabs": "3.8.29",
    "@react-spectrum/theme-default": "3.5.23",
    "astro": "^5.6.1",
    "react": "^18.3.1",
    "react-aria": "3.46.0",
    "react-aria-components": "1.15.1",
    "react-dom": "^18.3.1",
    "react-stately": "3.44.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.8.2"
  }
}
