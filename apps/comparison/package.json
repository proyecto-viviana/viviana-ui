{
  "name": "@proyecto-viviana/comparison",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Astro comparison app for React Spectrum and Proyecto Viviana parity review",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "report:gaps": "tsx scripts/report-catalogue-gaps.ts",
    "test:button": "playwright test e2e/button-visual.spec.ts e2e/button-family-contract.spec.ts --reporter=line",
    "test:buttons": "playwright test e2e/button-family-contract.spec.ts --reporter=line",
    "test:catalogue": "playwright test e2e/catalogue-controls.spec.ts --reporter=line",
    "test:contract": "playwright test e2e/styled-contract.spec.ts --reporter=line",
    "test:default": "playwright test e2e/default-state-visual.spec.ts e2e/default-state-pair-diff.spec.ts --reporter=line",
    "test:pair": "playwright test e2e/default-state-pair-diff.spec.ts --reporter=line",
    "test:dialog": "playwright test e2e/dialog-visual.spec.ts --reporter=line",
    "test:datepicker": "playwright test e2e/datepicker-visual.spec.ts --reporter=line",
    "test:select": "playwright test e2e/select-visual.spec.ts --reporter=line",
    "preview": "astro preview",
    "typecheck": "astro check",
    "dev:worker": "XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler ../../node_modules/.bin/wrangler dev --config wrangler.jsonc",
    "types": "XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler ../../node_modules/.bin/wrangler types src/worker-configuration.d.ts --config wrangler.jsonc",
    "deploy": "vp run build && XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler ../../node_modules/.bin/wrangler deploy --config wrangler.jsonc",
    "deploy:dry-run": "vp run build && XDG_CONFIG_HOME=/tmp/proyecto-viviana-wrangler ../../node_modules/.bin/wrangler deploy --dry-run --config wrangler.jsonc"
  },
  "overrides": {
    "lodash": "^4.17.23"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.2",
    "@astrojs/solid-js": "^5.1.1",
    "@proyecto-viviana/solid-spectrum": "workspace:*",
    "@proyecto-viviana/solid-stately": "workspace:*",
    "@proyecto-viviana/solidaria": "workspace:*",
    "@proyecto-viviana/solidaria-components": "workspace:*",
    "@react-spectrum/s2": "^1.3.0",
    "astro": "^5.6.1",
    "react": "^19.2.5",
    "react-aria": "3.46.0",
    "react-aria-components": "1.15.1",
    "react-dom": "^19.2.5",
    "react-stately": "3.44.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2",
    "typescript": "^5.8.2"
  }
}
