---
import ReactMount from "../../components/ReactMount.astro";
import SolidMount from "../../components/SolidMount.astro";
import { getComponentControlGroup } from "@comparison/data/component-controls";
import { getComponentCoverage } from "@comparison/data/coverage";
import {
  comparisonEntries,
  layerOrder,
  type ComparisonEntry,
  type ComparisonLayerId,
} from "@comparison/data/comparison-manifest";
import { getVisualStateTargets } from "@comparison/data/visual-state-matrix";
import "@comparison/styles/global.css";

export function getStaticPaths() {
  return comparisonEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: ComparisonEntry };
const controlGroup = getComponentControlGroup(entry);
const coverage = getComponentCoverage(entry, controlGroup);
const visualStates = getVisualStateTargets(entry);
const playgroundLayer: ComparisonLayerId = "styled";
const playgroundTrack = entry.layers[playgroundLayer];
const supportingLayers = layerOrder.filter((layer) => layer !== playgroundLayer);

const layerTitles: Record<ComparisonLayerId, string> = {
  styled: "Styled Layer",
  components: "Component Layer",
  headless: "Headless Layer",
  state: "State Layer",
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{entry.title} | Solid Spectrum</title>
  </head>
  <body class="comparison-app s2-docs" data-theme="system" data-resolved-theme="light">
    <div class="s2-topbar">
      <a href="/" class="s2-brand" aria-label="Solid Spectrum home">
        <span class="s2-brand-mark" aria-hidden="true">S</span>
        <span>Solid Spectrum</span>
      </a>
      <button class="s2-search" type="button">
        <span>Search Solid Spectrum</span>
        <kbd>/</kbd>
      </button>
      <nav class="s2-topnav" aria-label="Top navigation">
        <a href="/">Docs</a>
        {entry.docsUrl ? <a href={entry.docsUrl}>React Spectrum</a> : null}
        <a href="https://www.npmjs.com/package/@proyecto-viviana/solid-spectrum">npm</a>
      </nav>
      <button class="s2-theme-toggle" type="button" data-theme-toggle aria-label="Switch color theme">
        <span data-theme-toggle-icon>system</span>
      </button>
    </div>

    <div class="s2-layout">
      <aside class="s2-sidebar">
        <nav class="s2-nav" aria-label="Components">
          <p>Overview</p>
          <a href="/">Getting started</a>
          <p>Components</p>
          {comparisonEntries.map((componentEntry) => (
            <a
              href={`/components/${componentEntry.slug}`}
              aria-current={componentEntry.slug === entry.slug ? "page" : undefined}
            >
              {componentEntry.title}
            </a>
          ))}
          <p>Guides</p>
          <a href="#visual-state-coverage">Visual parity</a>
          <a href="#api">API coverage</a>
          <p>Reference</p>
          {entry.docsUrl ? <a href={entry.docsUrl}>S2 docs</a> : null}
        </nav>
      </aside>

      <main class="s2-main">
        <section class="s2-hero" aria-labelledby="page-title">
          <h1 id="page-title">{entry.title}</h1>
          <p>{entry.summary}</p>
          <div class="s2-hero-meta">
            <span class={`s2-pill s2-pill--${entry.parity}`}>{entry.parity}</span>
            <span class={`s2-pill s2-pill--${entry.componentStatus}`}>{entry.componentStatus}</span>
            <span class="s2-pill">{coverage.overall}% coverage</span>
          </div>
        </section>

        <section class="s2-example" id="example" aria-labelledby="example-title">
          <div class="s2-example-preview">
            <div class="s2-comparison-frame">
              <article class="s2-framework-panel" data-framework="react">
                <header>
                  <span>React</span>
                  <strong>React Spectrum S2</strong>
                  <em>{playgroundTrack.react}</em>
                </header>
                {playgroundTrack.react === "live" ? (
                  <ReactMount componentSlug={entry.slug} layer={playgroundLayer} />
                ) : (
                  <div class="s2-empty-state">
                    {playgroundTrack.react === "missing"
                      ? "React reference is missing."
                      : "React reference is tracked but not wired yet."}
                  </div>
                )}
              </article>

              <article class="s2-framework-panel" data-framework="solid">
                <header>
                  <span>Solid</span>
                  <strong>solid-spectrum</strong>
                  <em>{playgroundTrack.solid}</em>
                </header>
                {playgroundTrack.solid === "live" ? (
                  <SolidMount componentSlug={entry.slug} layer={playgroundLayer} />
                ) : (
                  <div class="s2-empty-state">
                    {playgroundTrack.solid === "missing"
                      ? "Solid implementation is missing."
                      : "Solid implementation is tracked but not wired yet."}
                  </div>
                )}
              </article>
            </div>
          </div>

          <div class="s2-example-controls">
            <h2 id="example-title">Example</h2>
            <p>{controlGroup.note}</p>
            <fieldset class="s2-radio-group s2-theme-control">
              <legend>Color scheme</legend>
              <div>
                <label>
                  <input type="radio" name="comparisonTheme" value="system" checked />
                  <span>system</span>
                </label>
                <label>
                  <input type="radio" name="comparisonTheme" value="light" />
                  <span>light</span>
                </label>
                <label>
                  <input type="radio" name="comparisonTheme" value="dark" />
                  <span>dark</span>
                </label>
              </div>
            </fieldset>
            {controlGroup.controls.length > 0 ? (
              <form
                class="s2-prop-controls"
                data-comparison-controls={entry.slug}
                data-control-coverage={controlGroup.coverage}
              >
                {controlGroup.controls.map((control) => (
                  <div class="s2-prop-control">
                    {control.kind === "text" ? (
                      <label class="s2-field">
                        <span>{control.label}</span>
                        <input name={control.name} value={String(control.defaultValue)} />
                      </label>
                    ) : control.kind === "select" ? (
                      <label class="s2-field">
                        <span>{control.label}</span>
                        <select name={control.name}>
                          {control.options?.map((option) => (
                            <option
                              value={option.value}
                              selected={option.value === control.defaultValue}
                            >
                              {option.label}
                            </option>
                          ))}
                        </select>
                      </label>
                    ) : control.kind === "radio" ? (
                      <fieldset class="s2-radio-group">
                        <legend>{control.label}</legend>
                        <div>
                          {control.options?.map((option) => (
                            <label>
                              <input
                                type="radio"
                                name={control.name}
                                value={option.value}
                                checked={option.value === control.defaultValue}
                              />
                              <span>{option.label}</span>
                            </label>
                          ))}
                        </div>
                      </fieldset>
                    ) : (
                      <label class="s2-switch">
                        <input name={control.name} type="checkbox" />
                        <span>{control.label}</span>
                      </label>
                    )}
                  </div>
                ))}
                <button type="button" class="s2-reset" data-reset-controls>Reset</button>
              </form>
            ) : (
              <div class="s2-empty-state">
                Interactive S2 prop controls are missing for this component.
              </div>
            )}
          </div>
        </section>

        <section class="s2-section" id="coverage" aria-labelledby="coverage-title">
          <div class="s2-section-heading">
            <h2 id="coverage-title">Coverage</h2>
            <span>{coverage.overall}%</span>
          </div>
          <div class="s2-coverage-list">
            {coverage.metrics.map((item) => (
              <div class="s2-coverage-row">
                <span>{item.label}</span>
                <div class="s2-meter"><span style={`width: ${item.value}%`}></span></div>
                <strong>{item.value}%</strong>
              </div>
            ))}
          </div>
        </section>

        <section class="s2-section" id="visual-state-coverage" aria-labelledby="visual-title">
          <div class="s2-section-heading">
            <h2 id="visual-title">Visual State Coverage</h2>
            <span>{visualStates.length} states</span>
          </div>
          <div class="s2-state-list">
            {visualStates.map((state) => (
              <article class="s2-state-row">
                <div>
                  <span>{state.kind}</span>
                  <h3>{state.label}</h3>
                  <p>{state.note}</p>
                </div>
                <div>
                  <span class={`s2-pill s2-pill--${state.react}`}>React {state.react}</span>
                  <span class={`s2-pill s2-pill--${state.solid}`}>Solid {state.solid}</span>
                  <span class={`s2-pill s2-pill--${state.pairDiff}`}>{state.pairDiff}</span>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="s2-section" id="api" aria-labelledby="api-title">
          <div class="s2-section-heading">
            <h2 id="api-title">API</h2>
            <span>{controlGroup.apiProps.length || "missing"}</span>
          </div>
          {controlGroup.apiProps.length > 0 ? (
            <div class="s2-api-table" role="table" aria-label={`${entry.title} API props`}>
              {controlGroup.apiProps.map((prop) => (
                <div role="row">
                  <code role="cell">{prop}</code>
                  <span role="cell">tracked</span>
                </div>
              ))}
            </div>
          ) : (
            <div class="s2-empty-state">API prop metadata has not been imported yet.</div>
          )}
        </section>

        {supportingLayers.map((layer) => {
          const track = entry.layers[layer];

          return (
            <section class="s2-section" id={layer} aria-labelledby={`${layer}-title`}>
              <div class="s2-section-heading">
                <h2 id={`${layer}-title`}>{layerTitles[layer]}</h2>
                <span>{track.solid}</span>
              </div>
              <p>{track.summary}</p>
              <p>{track.note}</p>
            </section>
          );
        })}
      </main>

      <aside class="s2-toc" aria-label="On this page">
        <p>On this page</p>
        <a href="#page-title">{entry.title}</a>
        <a href="#example">Example</a>
        <a href="#coverage">Coverage</a>
        <a href="#visual-state-coverage">Visual State Coverage</a>
        <a href="#api">API</a>
        {supportingLayers.map((layer) => (
          <a href={`#${layer}`}>{layerTitles[layer]}</a>
        ))}
        <div class="s2-toc-actions">
          {entry.docsUrl ? <a href={entry.docsUrl}>S2 source</a> : null}
        </div>
      </aside>
    </div>

    <script>
      import "@comparison/scripts/docs-theme";
    </script>
    <script is:inline>
      const panel = document.querySelector("[data-comparison-controls]");
      const form = panel instanceof HTMLFormElement ? panel : null;
      const resetButton = form?.querySelector("[data-reset-controls]");
      const component = form?.dataset.comparisonControls;
      const defaultsByComponent = {
        actionbutton: {
          children: "Inspect",
          size: "M",
          staticColor: "none",
          isQuiet: false,
          isDisabled: false,
          isPending: false,
        },
        button: {
          children: "Save",
          variant: "primary",
          fillStyle: "fill",
          size: "M",
          staticColor: "none",
          isDisabled: false,
          isPending: false,
        },
      };
      const defaults = defaultsByComponent[component] ?? {};

      function readControls() {
        if (!form) {
          return defaults;
        }

        const data = new FormData(form);
        const values = {};
        for (const [key, defaultValue] of Object.entries(defaults)) {
          values[key] =
            typeof defaultValue === "boolean"
              ? data.get(key) === "on"
              : String(data.get(key) || defaultValue);
        }
        return values;
      }

      function writeControls(values) {
        if (!form) {
          return;
        }

        for (const [key, value] of Object.entries(values)) {
          const fields = Array.from(form.elements).filter((field) => field.name === key);
          for (const field of fields) {
            if (field instanceof HTMLInputElement && field.type === "checkbox") {
              field.checked = Boolean(value);
            } else if (field instanceof HTMLInputElement && field.type === "radio") {
              field.checked = field.value === String(value);
            } else if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement) {
              field.value = String(value ?? "");
            }
          }
        }
      }

      function toProps(values) {
        const props = {};
        for (const [key, value] of Object.entries(values)) {
          props[key] = key === "staticColor" && value === "none" ? undefined : value;
        }
        return props;
      }

      function dispatchControls(values, updateUrl = true) {
        if (updateUrl) {
          const url = new URL(window.location.href);
          for (const [key, value] of Object.entries(values)) {
            if (value === defaults[key] || value === "" || value === false) {
              url.searchParams.delete(key);
            } else {
              url.searchParams.set(key, String(value));
            }
          }
          window.history.replaceState(null, "", url);
        }

        window.dispatchEvent(new CustomEvent("comparison:controls-change", {
          detail: { component, props: toProps(values) },
        }));
      }

      if (form && component) {
        const params = new URLSearchParams(window.location.search);
        const initial = { ...defaults };
        for (const [key, defaultValue] of Object.entries(defaults)) {
          initial[key] =
            typeof defaultValue === "boolean"
              ? params.get(key) === "true"
              : params.get(key) || defaultValue;
        }
        writeControls(initial);
        dispatchControls(initial, false);
        form.addEventListener("input", () => dispatchControls(readControls()));
        form.addEventListener("change", () => dispatchControls(readControls()));
      }

      resetButton?.addEventListener("click", () => {
        writeControls(defaults);
        dispatchControls(defaults);
      });
    </script>
  </body>
</html>
