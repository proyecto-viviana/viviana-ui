---
import ReactMount from "../../components/ReactMount.astro";
import SolidMount from "../../components/SolidMount.astro";
import {
  comparisonEntries,
  layerOrder,
  type ComparisonEntry,
  type ComparisonLayerId,
} from "@comparison/data/comparison-manifest";
import {
  buttonDemoDefaults,
  buttonFillStyleOptions,
  buttonSizeOptions,
  buttonStaticColorOptions,
  buttonVariantOptions,
} from "@comparison/data/button-demo";
import { getVisualStateTargets } from "@comparison/data/visual-state-matrix";
import "@comparison/styles/global.css";

export function getStaticPaths() {
  return comparisonEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: ComparisonEntry };
const visualStates = getVisualStateTargets(entry);

const layerTitles: Record<ComparisonLayerId, string> = {
  styled: "Styled Layer",
  components: "Component Layer",
  headless: "Headless Layer",
  state: "State Layer",
};

const playgroundLayer: ComparisonLayerId = "styled";
const playgroundTrack = entry.layers[playgroundLayer];
const supportingLayers = layerOrder.filter((layer) => layer !== playgroundLayer);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{entry.title} Comparison</title>
  </head>
  <body class="comparison-app">
    <main class="docs-shell">
      <header class="docs-topbar">
        <div>
          <a href="/" class="back-link">Components</a>
          <h1>{entry.title}</h1>
        </div>
        {entry.docsUrl ? (
          <a class="entry-link" href={entry.docsUrl}>
            React Spectrum documentation
          </a>
        ) : null}
      </header>

      <div class="docs-layout docs-layout--detail">
        <aside class="docs-rail">
          <nav class="component-nav" aria-label="Components">
            <p>Components</p>
            {comparisonEntries.map((componentEntry) => (
              <a
                href={`/components/${componentEntry.slug}`}
                aria-current={componentEntry.slug === entry.slug ? "page" : undefined}
              >
                {componentEntry.title}
              </a>
            ))}
          </nav>
        </aside>

        <div class="docs-content">
          <section class="section-block detail-summary" id="overview">
            <div class="rail-status">
              <span class={`status-pill status-pill--${entry.parity}`}>{entry.parity}</span>
              <span class={`status-pill status-pill--${entry.componentStatus}`}>
                {entry.componentStatus}
              </span>
              <span class="category-pill">{entry.category}</span>
            </div>
            <p class="hero-copy">{entry.summary}</p>
          </section>

          <section class="section-block playground-block" id="playground">
            <div class="section-heading">
              <h2>Playground</h2>
              <p>{playgroundTrack.summary}</p>
              <p class="layer-note">{playgroundTrack.note}</p>
            </div>

            <div class="playground-surface">
              {entry.slug === "button" ? (
                <div class="component-controls component-controls--embedded" data-comparison-controls="button">
                  <form class="control-grid">
                    <label>
                      <span>children</span>
                      <input name="children" value={buttonDemoDefaults.children} />
                    </label>
                    <label>
                      <span>variant</span>
                      <select name="variant">
                        {buttonVariantOptions.map((option) => (
                          <option value={option} selected={option === buttonDemoDefaults.variant}>
                            {option}
                          </option>
                        ))}
                      </select>
                    </label>
                    <label>
                      <span>fillStyle</span>
                      <select name="fillStyle">
                        {buttonFillStyleOptions.map((option) => (
                          <option value={option} selected={option === buttonDemoDefaults.fillStyle}>
                            {option}
                          </option>
                        ))}
                      </select>
                    </label>
                    <label>
                      <span>size</span>
                      <select name="size">
                        {buttonSizeOptions.map((option) => (
                          <option value={option} selected={option === buttonDemoDefaults.size}>
                            {option}
                          </option>
                        ))}
                      </select>
                    </label>
                    <label>
                      <span>staticColor</span>
                      <select name="staticColor">
                        <option value="">none</option>
                        {buttonStaticColorOptions.map((option) => (
                          <option value={option}>{option}</option>
                        ))}
                      </select>
                    </label>
                    <label class="checkbox-control">
                      <input name="isDisabled" type="checkbox" />
                      <span>isDisabled</span>
                    </label>
                    <label class="checkbox-control">
                      <input name="isPending" type="checkbox" />
                      <span>isPending</span>
                    </label>
                    <button type="button" class="reset-control" data-reset-controls>Reset</button>
                  </form>
                </div>
              ) : null}

              <div class="comparison-grid">
                <article class="framework-card">
                  <div class="framework-card-head">
                    <div>
                      <span class="framework-label">React</span>
                      <h3>React Spectrum stack</h3>
                    </div>
                    <span class={`status-pill status-pill--${playgroundTrack.react}`}>
                      {playgroundTrack.react}
                    </span>
                  </div>
                  {playgroundTrack.react === "live" ? (
                    <ReactMount componentSlug={entry.slug} layer={playgroundLayer} />
                  ) : (
                    <div class="comparison-empty-state">
                      {playgroundTrack.react === "na"
                        ? "No direct React layer exists here."
                        : playgroundTrack.react === "missing"
                          ? "Missing React reference implementation."
                          : "This React comparison is tracked but not wired yet."}
                    </div>
                  )}
                </article>

                <article class="framework-card">
                  <div class="framework-card-head">
                    <div>
                      <span class="framework-label">Solid</span>
                      <h3>Solidaria stack</h3>
                    </div>
                    <span class={`status-pill status-pill--${playgroundTrack.solid}`}>
                      {playgroundTrack.solid}
                    </span>
                  </div>
                  {playgroundTrack.solid === "live" ? (
                    <SolidMount componentSlug={entry.slug} layer={playgroundLayer} />
                  ) : (
                    <div class="comparison-empty-state">
                      {playgroundTrack.solid === "na"
                        ? "No direct Solid layer exists here."
                        : playgroundTrack.solid === "missing"
                          ? "Missing Solid implementation."
                          : "This Solid comparison is tracked but not wired yet."}
                    </div>
                  )}
                </article>
              </div>
            </div>
          </section>

          <section class="section-block state-matrix" id="visual-state-coverage">
            <div class="section-heading">
              <h2>Visual State Coverage</h2>
            </div>
            <div class="state-matrix-grid">
              {visualStates.map((state) => (
                <article class="state-row">
                  <div>
                    <span class="state-kind">{state.kind}</span>
                    <h3>{state.label}</h3>
                    <p>{state.note}</p>
                  </div>
                  <div class="state-status-stack">
                    <span class={`state-pill state-pill--${state.react}`}>
                      React {state.react}
                    </span>
                    <span class={`state-pill state-pill--${state.solid}`}>
                      Solid {state.solid}
                    </span>
                    <span class={`state-pill state-pill--${state.pairDiff}`}>
                      Pair diff {state.pairDiff}
                    </span>
                  </div>
                </article>
              ))}
            </div>
          </section>

      {supportingLayers.map((layer) => {
        const track = entry.layers[layer];

        return (
          <section class="section-block layer-block" id={layer}>
            <div class="section-heading">
              <h2>{layerTitles[layer]}</h2>
              <p>{track.summary}</p>
              <p class="layer-note">{track.note}</p>
            </div>

            <div class="comparison-grid">
              <article class="framework-card">
                <div class="framework-card-head">
                  <div>
                    <span class="framework-label">React</span>
                    <h3>React Spectrum stack</h3>
                  </div>
                  <span class={`status-pill status-pill--${track.react}`}>
                    {track.react}
                  </span>
                </div>
                {track.react === "live" ? (
                  <ReactMount componentSlug={entry.slug} layer={layer} />
                ) : (
                  <div class="comparison-empty-state">
                    {track.react === "na"
                      ? "No direct React layer exists here."
                      : track.react === "missing"
                        ? "Missing React reference implementation."
                        : "This React comparison is tracked but not wired yet."}
                  </div>
                )}
              </article>

              <article class="framework-card">
                <div class="framework-card-head">
                  <div>
                    <span class="framework-label">Solid</span>
                    <h3>Solidaria stack</h3>
                  </div>
                  <span class={`status-pill status-pill--${track.solid}`}>
                    {track.solid}
                  </span>
                </div>
                {track.solid === "live" ? (
                  <SolidMount componentSlug={entry.slug} layer={layer} />
                ) : (
                  <div class="comparison-empty-state">
                    {track.solid === "na"
                      ? "No direct Solid layer exists here."
                      : track.solid === "missing"
                        ? "Missing Solid implementation."
                        : "This Solid comparison is tracked but not wired yet."}
                  </div>
                )}
              </article>
            </div>
          </section>
        );
      })}
        </div>

        <aside class="docs-toc" aria-label="On this page">
          <p>On this page</p>
          <a href="#overview">Overview</a>
          <a href="#playground">Playground</a>
          <a href="#visual-state-coverage">Visual State Coverage</a>
          {supportingLayers.map((layer) => (
            <a href={`#${layer}`}>{layerTitles[layer]}</a>
          ))}
          <div class="toc-divider"></div>
          <div class="rail-status">
            <span class={`status-pill status-pill--${entry.parity}`}>{entry.parity}</span>
            <span class={`status-pill status-pill--${entry.componentStatus}`}>
              {entry.componentStatus}
            </span>
            <span class="category-pill">{entry.category}</span>
          </div>
          <ul class="entry-notes">
            {entry.gapSummary.map((note) => (
              <li>{note}</li>
            ))}
          </ul>
        </aside>
      </div>
    </main>
    <script is:inline>
      const panel = document.querySelector('[data-comparison-controls="button"]');
      const form = panel?.querySelector("form");
      const resetButton = panel?.querySelector("[data-reset-controls]");
      const defaults = {
        children: "Save",
        variant: "primary",
        fillStyle: "fill",
        size: "M",
        staticColor: "",
        isDisabled: false,
        isPending: false,
      };

      function readButtonControls() {
        if (!(form instanceof HTMLFormElement)) {
          return defaults;
        }

        const data = new FormData(form);
        return {
          children: String(data.get("children") || defaults.children),
          variant: String(data.get("variant") || defaults.variant),
          fillStyle: String(data.get("fillStyle") || defaults.fillStyle),
          size: String(data.get("size") || defaults.size),
          staticColor: String(data.get("staticColor") || ""),
          isDisabled: data.get("isDisabled") === "on",
          isPending: data.get("isPending") === "on",
        };
      }

      function writeButtonControls(values) {
        if (!(form instanceof HTMLFormElement)) {
          return;
        }

        for (const [key, value] of Object.entries(values)) {
          const field = form.elements.namedItem(key);
          if (field instanceof HTMLInputElement && field.type === "checkbox") {
            field.checked = Boolean(value);
          } else if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement) {
            field.value = String(value ?? "");
          }
        }
      }

      function dispatchButtonControls(values, updateUrl = true) {
        const props = {
          children: values.children || defaults.children,
          variant: values.variant,
          fillStyle: values.fillStyle,
          size: values.size,
          staticColor: values.staticColor || undefined,
          isDisabled: Boolean(values.isDisabled),
          isPending: Boolean(values.isPending),
        };

        if (updateUrl) {
          const url = new URL(window.location.href);
          for (const [key, value] of Object.entries(values)) {
            if (value === defaults[key] || value === "" || value === false) {
              url.searchParams.delete(key);
            } else {
              url.searchParams.set(key, String(value));
            }
          }
          window.history.replaceState(null, "", url);
        }

        window.dispatchEvent(new CustomEvent("comparison:controls-change", {
          detail: { component: "button", props },
        }));
      }

      if (form instanceof HTMLFormElement) {
        const params = new URLSearchParams(window.location.search);
        const initial = {
          ...defaults,
          children: params.get("children") || defaults.children,
          variant: params.get("variant") || defaults.variant,
          fillStyle: params.get("fillStyle") || defaults.fillStyle,
          size: params.get("size") || defaults.size,
          staticColor: params.get("staticColor") || "",
          isDisabled: params.get("isDisabled") === "true",
          isPending: params.get("isPending") === "true",
        };
        writeButtonControls(initial);
        dispatchButtonControls(initial, false);
        form.addEventListener("input", () => dispatchButtonControls(readButtonControls()));
        form.addEventListener("change", () => dispatchButtonControls(readButtonControls()));
      }

      resetButton?.addEventListener("click", () => {
        writeButtonControls(defaults);
        dispatchButtonControls(defaults);
      });
    </script>
  </body>
</html>
