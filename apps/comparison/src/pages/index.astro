---
import {
  comparisonEntries,
  missingOfficialComparisonEntries,
  officialComparisonEntries,
} from "@comparison/data/comparison-manifest";
import { reactSpectrumCatalogueSource } from "@comparison/data/react-spectrum-catalogue";
import { officialVisualStateSummary } from "@comparison/data/visual-state-matrix";
import "@comparison/styles/global.css";

const matchedCount = comparisonEntries.filter((entry) => entry.parity === "matched").length;
const partialCount = comparisonEntries.filter((entry) => entry.parity === "partial").length;
const gapCount = comparisonEntries.filter((entry) => entry.parity === "gap").length;
const liveCount = comparisonEntries.filter((entry) => entry.priority === "live").length;
const officialCount = officialComparisonEntries.length;
const missingOfficialCount = missingOfficialComparisonEntries.length;
const snapshottedStateCount = officialVisualStateSummary.snapshottedStates;
const strictStateCount = officialVisualStateSummary.strictPairDiffStates;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Comparison App</title>
  </head>
  <body class="comparison-app">
    <main class="docs-shell">
      <header class="docs-topbar">
        <div>
          <p class="eyebrow">Comparison Harness</p>
          <h1>React Spectrum S2 parity</h1>
        </div>
        <a class="entry-link" href={reactSpectrumCatalogueSource.url}>React Spectrum catalogue</a>
      </header>

      <div class="docs-layout">
        <aside class="docs-rail">
          <form class="catalogue-controls" data-catalogue-controls>
            <label>
              <span>Search</span>
              <input name="query" type="search" placeholder="Button, Dialog, Picker" />
            </label>
            <label>
              <span>Parity</span>
              <select name="parity">
                <option value="all">All</option>
                <option value="matched">Matched</option>
                <option value="partial">Partial</option>
                <option value="gap">Gap</option>
              </select>
            </label>
            <label>
              <span>Status</span>
              <select name="status">
                <option value="all">All</option>
                <option value="live">Live</option>
                <option value="tracked">Tracked</option>
              </select>
            </label>
            <label>
              <span>Source</span>
              <select name="source">
                <option value="all">All</option>
                <option value="react-spectrum-s2">Official S2</option>
                <option value="legacy-solidaria">Legacy</option>
              </select>
            </label>
            <label>
              <span>Sort</span>
              <select name="sort">
                <option value="docs">Docs order</option>
                <option value="name">Name</option>
                <option value="parity">Parity</option>
                <option value="status">Status</option>
              </select>
            </label>
          </form>

          <div class="stat-list">
            <div><span>Live routes</span><strong>{liveCount}</strong></div>
            <div><span>Official S2</span><strong>{officialCount}</strong></div>
            <div><span>Official gaps</span><strong>{missingOfficialCount}</strong></div>
            <div><span>State screenshots</span><strong>{snapshottedStateCount}</strong></div>
            <div><span>Strict pairs</span><strong>{strictStateCount}</strong></div>
            <div><span>Matched</span><strong>{matchedCount}</strong></div>
            <div><span>Partial</span><strong>{partialCount}</strong></div>
            <div><span>Gap</span><strong>{gapCount}</strong></div>
          </div>
        </aside>

        <section class="docs-content">
          <div class="section-heading">
            <h2>Components</h2>
            <p>
              Official S2 catalogue order, implementation gaps, and strict visual
              coverage in one sortable list.
            </p>
          </div>
          <div class="result-count" data-result-count>{comparisonEntries.length} components</div>
          <div class="entry-grid" data-entry-list>
            {comparisonEntries.map((entry, index) => (
              <a
                href={`/components/${entry.slug}`}
                class="entry-card"
                data-entry-card
                data-index={index}
                data-title={entry.title}
                data-summary={entry.summary}
                data-parity={entry.parity}
                data-status={entry.priority}
                data-component-status={entry.componentStatus}
                data-source={entry.catalogueSource}
                data-category={entry.category}
              >
              <div class="entry-card-top">
                <span class={`status-pill status-pill--${entry.parity}`}>{entry.parity}</span>
                <span class={`status-pill status-pill--${entry.componentStatus}`}>
                  {entry.componentStatus}
                </span>
                <span class="category-pill">{entry.category}</span>
              </div>
              <h3>{entry.title}</h3>
              <p>{entry.summary}</p>
              <ul class="entry-notes">
                {entry.gapSummary.slice(0, 2).map((note) => (
                  <li>{note}</li>
                ))}
              </ul>
              <span class="entry-link">
                Open comparison
              </span>
            </a>
            ))}
          </div>
        </section>
      </div>
    </main>
    <script is:inline>
      const controls = document.querySelector("[data-catalogue-controls]");
      const list = document.querySelector("[data-entry-list]");
      const count = document.querySelector("[data-result-count]");
      const cards = Array.from(document.querySelectorAll("[data-entry-card]"));

      function normalize(value) {
        return String(value || "").toLowerCase();
      }

      function applyCatalogueControls() {
        if (!(controls instanceof HTMLFormElement) || !(list instanceof HTMLElement)) {
          return;
        }

        const data = new FormData(controls);
        const query = normalize(data.get("query"));
        const parity = String(data.get("parity") || "all");
        const status = String(data.get("status") || "all");
        const source = String(data.get("source") || "all");
        const sort = String(data.get("sort") || "docs");
        const visible = [];

        for (const card of cards) {
          if (!(card instanceof HTMLElement)) {
            continue;
          }

          const searchable = normalize(`${card.dataset.title} ${card.dataset.summary} ${card.dataset.category}`);
          const matches =
            (!query || searchable.includes(query)) &&
            (parity === "all" || card.dataset.parity === parity) &&
            (status === "all" || card.dataset.status === status) &&
            (source === "all" || card.dataset.source === source);

          card.hidden = !matches;
          if (matches) {
            visible.push(card);
          }
        }

        const sorted = [...visible].sort((a, b) => {
          if (sort === "name") {
            return String(a.dataset.title).localeCompare(String(b.dataset.title));
          }
          if (sort === "parity") {
            return String(a.dataset.parity).localeCompare(String(b.dataset.parity)) ||
              Number(a.dataset.index) - Number(b.dataset.index);
          }
          if (sort === "status") {
            return String(a.dataset.componentStatus).localeCompare(String(b.dataset.componentStatus)) ||
              Number(a.dataset.index) - Number(b.dataset.index);
          }
          return Number(a.dataset.index) - Number(b.dataset.index);
        });

        for (const card of sorted) {
          list.append(card);
        }

        if (count) {
          count.textContent = `${visible.length} component${visible.length === 1 ? "" : "s"}`;
        }
      }

      controls?.addEventListener("input", applyCatalogueControls);
      controls?.addEventListener("change", applyCatalogueControls);
      applyCatalogueControls();
    </script>
  </body>
</html>
