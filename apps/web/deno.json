{
  "tasks": {
    "dev": "deno run -A npm:vite dev",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "deploy": "deno task build && npx wrangler deploy",
    "test:e2e": "bun run playwright test"
  },
  "imports": {
    "solid-js": "npm:solid-js@^1.9.10",
    "solid-js/web": "npm:solid-js@^1.9.10/web",
    "solid-js/store": "npm:solid-js@^1.9.10/store",
    "@tanstack/solid-router": "npm:@tanstack/solid-router@1.142.8",
    "@tanstack/solid-start": "npm:@tanstack/solid-start@1.142.8",
    "solid-icons/": "npm:solid-icons@^1.1.0/",
    "@proyecto-viviana/solidaria": "jsr:@proyecto-viviana/solidaria@^0.0.7",
    "@proyecto-viviana/ui": "jsr:@proyecto-viviana/ui@^0.1.8",
    "@proyecto-viviana/solidaria-components": "jsr:@proyecto-viviana/solidaria-components@^0.0.7",
    "@proyecto-viviana/solid-stately": "jsr:@proyecto-viviana/solid-stately@^0.0.7"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "strict": true,
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"]
  }
}
