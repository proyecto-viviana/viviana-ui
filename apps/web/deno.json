{
  "tasks": {
    "dev": "deno run -A npm:vite dev",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "deploy": "deno task build && npx wrangler deploy",
    "test:e2e": "bun run playwright test"
  },
  "imports": {
    "solid-js": "npm:solid-js@^1.9.10",
    "solid-js/web": "npm:solid-js@^1.9.10/web",
    "solid-js/store": "npm:solid-js@^1.9.10/store",
    "@tanstack/solid-router": "npm:@tanstack/solid-router@1.161.1",
    "@tanstack/solid-start": "npm:@tanstack/solid-start@1.161.1",
    "solid-icons/": "npm:solid-icons@^1.1.0/",
    "vite": "npm:vite@^7.3.1",
    "tailwindcss": "npm:tailwindcss@^4.2.0",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.0",
    "@cloudflare/vite-plugin": "npm:@cloudflare/vite-plugin@^1.25.2",
    "vite-tsconfig-paths": "npm:vite-tsconfig-paths@^6.1.1",
    "vite-plugin-solid": "npm:vite-plugin-solid@^2.11.10",
    "@proyecto-viviana/solidaria": "jsr:@proyecto-viviana/solidaria@^0.2.5",
    "@proyecto-viviana/silapse": "jsr:@proyecto-viviana/silapse@^0.3.5",
    "@proyecto-viviana/solidaria-components": "jsr:@proyecto-viviana/solidaria-components@^0.2.5",
    "@proyecto-viviana/solid-stately": "jsr:@proyecto-viviana/solid-stately@^0.2.4"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "strict": true,
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"]
  }
}
